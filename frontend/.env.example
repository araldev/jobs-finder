# Backend URL for Next.js Route Handlers (server-side only).
# Optional as of Phase 3 (LLM in Next.js). No route handler uses
# BACKEND_URL anymore — the LLM endpoints now talk directly to
# MiniMax via `LLM_BASE_URL` below, and the data endpoints talk
# directly to Supabase via `frontend/src/lib/supabase-queries.ts`.
# The Python backend is still required for the scraper / scheduler
# process (separate concern), but no Next.js route handler
# proxies to it. This var will be removed entirely after the
# Python backend's LLM code is deleted (separate follow-up task).
# For LAN access, replace localhost with the backend machine's IP:
#   BACKEND_URL=http://192.168.1.42:8000
# BACKEND_URL=http://localhost:8000

# API key for backend authentication (server-side only, never expose to browser).
# Optional as of Phase 3 — no Next.js route handler uses it anymore.
# Must match one of the keys in API_KEYS on the backend.
# BACKEND_API_KEY=your-api-key-here

# ── MiniMax LLM (Phase 3: LLM in Next.js) ──────────────────────────
# LLM_API_KEY is the kill switch — when unset, both `/api/cv/generate`
# and `/api/jobs/chat/stream` return 502 / SSE error events with a
# generic "LLM provider unavailable" message. Get a key from the
# MiniMax console. NEVER expose this var to the browser.
LLM_API_KEY=

# Optional. Defaults to https://api.minimax.io (the MiniMax production
# endpoint). Override for staging or a self-hosted MiniMax-compatible
# gateway. Trailing slashes are stripped automatically.
# LLM_BASE_URL=https://api.minimax.io

# Optional. Defaults to MiniMax-M3. Override per deployment if you
# want to A/B test other MiniMax model IDs.
# LLM_MODEL=MiniMax-M3

# Supabase configuration for client-side usage
NEXT_PUBLIC_SUPABASE_URL=<tu-project-url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<tu-anon-key>

# Internationalization (next-intl)
# Default: enabled. Set to "false" to disable the intl middleware chain
# entirely (routes go straight to Supabase updateSession). Escape hatch
# if an i18n slice regresses production traffic (design D14).
# NEXT_PUBLIC_I18N_ENABLED=true
