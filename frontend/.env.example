# Backend URL for the Next.js Route Handlers (server-side only).
# The browser NEVER reaches this URL directly — all calls are proxied
# through the Next.js server in src/app/api/* (see frontend/README.md
# "How to consume the backend API").
#
# This variable is read at request time via process.env.BACKEND_URL.
# It does NOT need the NEXT_PUBLIC_ prefix because Route Handlers run
# in the Node server runtime, not the browser.
BACKEND_URL=http://localhost:8000
