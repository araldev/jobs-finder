# =============================================================================
# jobs-finder — Environment variable template
# =============================================================================
#
# This file documents EVERY env var the service reads. Copy it to `.env`
# (gitignored) and fill in the values you want to override. Shell env vars
# always take precedence over `.env` entries (pydantic-settings standard
# precedence), so you can also use `export VAR=value` without touching
# this file.
#
# ─── TWO-LAYER CONFIG ───────────────────────────────────────────────────────
# Since the `toml-config-defaults` refactor, non-secret operational
# defaults (throttles, timeouts, domains, cache TTL, LLM params, etc.)
# live in `backend/config/default.toml` (versioned). The TOML layer is
# loaded by `load_settings()` and INJECTS into os.environ ONLY for keys
# that are not already set — so:
#
#   shell env var  >  .env entry  >  config/default.toml  >  field default
#
# Use THIS FILE for:
#   - Secrets: LINKEDIN_LI_AT, LLM_API_KEY, DATABASE_URL, etc.
#   - Per-environment switches: ENVIRONMENT, *_ENABLED, *_BACKEND,
#     LINKEDIN_HEADLESS, LINKEDIN_CORS_ALLOW_ORIGINS, API_KEYS.
#
# Use `backend/config/local.toml` (gitignored) for:
#   - Operator overrides of operational defaults without forking
#     `default.toml` or polluting `.env` with non-secret values.
#
# To temporarily override a TOML default locally, uncomment the line in
# the relevant section below (lines marked "see config/default.toml").
#
# The `Settings` class lives in
# `src/jobs_finder/infrastructure/config.py` — every field's default,
# validator, and per-field alias is documented there.
#
# Quick start:
#   cp .env.example .env
#   $EDITOR .env                 # set LLM_API_KEY at minimum
#   uv run uvicorn jobs_finder.main:app
# =============================================================================


# -----------------------------------------------------------------------------
# LinkedIn scraper (model-level env_prefix="LINKEDIN_")
# -----------------------------------------------------------------------------

# LinkedIn credentials for cookie extraction script.
# The script `scripts/extract_linkedin_cookies.py` reads these to log in
# and save `linkedin_cookies.json`. NEVER commit real values to the repo.
# Use direnv (`export LINKEDIN_EMAIL=... LINKEDIN_PASSWORD=...`) or a
# gitignored `backend/.env` instead.
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Per-request delay between LinkedIn calls (seconds). LinkedIn's anti-bot
# re-challenges fast bursts; 3.0 is the empirically safe default.
# LINKEDIN_THROTTLE_SECONDS=3.0  # see config/default.toml

# User-Agent header. Default is a modern-Chrome string that bypasses the
# most basic anti-bot filters. Override only if LinkedIn starts rejecting
# the default UA.
# LINKEDIN_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Run Chromium headless. `true` for CI/server, `false` for local debugging.
LINKEDIN_HEADLESS=true

# Per-request timeout (milliseconds). LinkedIn's search responds fast; 10s
# is comfortable.
# LINKEDIN_REQUEST_TIMEOUT_MS=10000  # see config/default.toml

# CORS allowlist. `*` is the dev default — NOT for production. Set to a
# comma-separated list of origins in any non-dev environment.
# LINKEDIN_CORS_ALLOW_ORIGINS=https://app.example.com,https://staging.example.com

# Root logger level. `INFO` for prod, `DEBUG` for local debugging.
# LINKEDIN_LOG_LEVEL=INFO  # see config/default.toml

# `json` for structured logs (prod/CI), `plain` for stdlib default
# formatter (local development).
# LINKEDIN_LOG_FORMAT=json  # see config/default.toml

# Operator's `li_at` session cookie (T-005 of `backend-linkedin-auth`,
# REQ-LA-SCR-001). The LinkedIn scraper injects the cookie into
# the Playwright `BrowserContext` before the first navigation,
# which restores the full SERP stream (~25 jobs/page) instead of
# the auth-walled variant (~3-5 jobs/page). Leave empty to run
# the scraper anonymously (v1 behavior; a WARNING is logged at
# startup). Set to your own `li_at` value to enable the auth path.
# SECURITY: NEVER commit a real value to this file or to the repo.
# Use direnv (`export LINKEDIN_LI_AT=...`) or a gitignored
# `backend/.env` instead. See backend/README.md "LinkedIn auth
# cookie (optional)" section for the full operator guide.
LINKEDIN_LI_AT=

# T-005 of `backend-linkedin-stealth` — the 3 supplementary
# LinkedIn cookies that Cloudflare+LinkedIn 2026 treat as a
# "real session" signal (REQ-LST-COOKIE-001). All 3 are
# OPTIONAL (the scraper runs anonymously with all 4 unset).
# Setting ALL 4 is the recommended baseline; the 3 here
# supplement `LINKEDIN_LI_AT` for LinkedIn + Cloudflare
# consistency. Each MUST be at least 8 characters (the
# `Settings._reject_short_*` validator catches operator
# typos). NEVER commit a real value to this file or to the
# repo. See backend/README.md "LinkedIn anti-bot stealth
# (multi-cookie + playwright-stealth)" section.
LINKEDIN_JSESSIONID=
LINKEDIN_BCOOKIE=
LINKEDIN_LI_GC=

# T-002 of `backend-linkedin-xvfb` (REQ-LXV-005) — the
# opt-in Xvfb switch. Set to a display string (e.g. `:99`)
# to run the LinkedIn scraper non-headless under a virtual
# X display (Xvfb). The browser has a real windowing context
# + real TLS / HTTP-2 SETTINGS frame, evading Cloudflare
# 2026's headless-Chromium fingerprint detection (the
# failure mode the cycle 2 `playwright-stealth` layer could
# not bypass). REQUIRES a running Xvfb server (use
# `bash scripts/start_xvfb.sh &` to start one — Linux only;
# install via `apt-get install -y xvfb`). When the display
# is set, the launch uses `headless=False` and adds the
# `--no-sandbox` + `--disable-dev-shm-usage` Chromium args.
# Leave empty (or commented) to keep the v1+v2 byte-identical
# `headless=True` behavior. See backend/README.md "Running
# under Xvfb" section for the full operator guide.
# LINKEDIN_XVFB_DISPLAY=:99

# T-005 of `backend-linkedin-xvfb` (REQ-LBSc-001) — the
# 5th LinkedIn cookie (F-4 fold-in per obs #375 §9). The
# `bscookie` is the operator's per-session browser
# fingerprint that LinkedIn's session check looks for in
# addition to the 4 cycle-2 cookies. The 2 shared
# validators in `Settings` (`_normalize_empty_*` +
# `_reject_short_*`) apply — the value MUST be at least 8
# characters. NEVER commit a real value to this file or
# to the repo. Leave empty to skip this cookie (the
# scraper runs with the remaining 4 cookies).
# LINKEDIN_BSCOOKIE=
# LINKEDIN_LAUNCH_CHANNEL=chrome  # system Chrome vs Playwright bundled Chromium


# -----------------------------------------------------------------------------
# LinkedIn cookie refresh (`linkedin-cookie-refresh` cycle 4)
# -----------------------------------------------------------------------------
#
# When the LinkedIn scraper detects the auth-wall or a Cloudflare challenge
# (the SERP returns 0 cards even with valid cookies), the
# `PlaywrightLinkedInCookieRefresher` re-logs in with the operator's
# `LINKEDIN_EMAIL` / `LINKEDIN_PASSWORD` and writes the new cookies back into
# the auth-cookie adapter. The 3 knobs below control when / how often /
# how long the refresh waits.
#
# 2FA / SMS checkpoints are NOT auto-resolved — see README "Cookie refresh
# (auto)" for the manual fallback when LinkedIn shows a challenge page.
# -----------------------------------------------------------------------------

# Master switch for auto-refresh on auth-wall / Cloudflare. Default `true`
# (zero-touch operation is the user's stated intent). Set to `false` to
# revert to the v1 "WARNING + return 0 jobs" behavior. The composition root
# wires a `DisabledLinkedInCookieRefresher` whose `refresh()` is identity
# (returns existing cookies unchanged) when this is `false`.
LINKEDIN_COOKIE_REFRESH_ENABLED=true

# Backoff window — the scraper skips refresh within this many seconds of the
# last attempt to prevent refresh-storm on per-scheduler-cycle cadence of
# ~25-35 min. Default `3600.0` (1 hour). MUST be positive (`gt=0.0`);
# operators who want zero backoff MUST set the kill switch instead.
# LINKEDIN_COOKIE_REFRESH_BACKOFF_SECONDS=3600.0

# Wall-clock cap on the post-login URL poll (seconds). Default `300.0` (5
# min) — matches the `extract_linkedin_cookies.py` precedent. MUST be
# positive (`gt=0.0`).
# LINKEDIN_COOKIE_REFRESH_TIMEOUT_SECONDS=300.0


# -----------------------------------------------------------------------------
# Indeed scraper (per-field AliasChoices)
# -----------------------------------------------------------------------------

# INDEED_USER_AGENT uses the same default as LinkedIn; uncomment to override.
# INDEED_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# INDEED_THROTTLE_SECONDS=3.0  # see config/default.toml
# INDEED_TIMEOUT_MS=15000  # see config/default.toml
# INDEED_DOMAIN=es.indeed.com  # see config/default.toml
# INDEED_MAX_PAGES=10  # see config/default.toml
# INDEED_INTER_PAGE_DELAY_SECONDS=1.0  # see config/default.toml


# -----------------------------------------------------------------------------
# InfoJobs scraper (per-field AliasChoices)
# -----------------------------------------------------------------------------

# INFOJOBS_USER_AGENT uses the same default as LinkedIn; uncomment to override.
# INFOJOBS_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# INFOJOBS_THROTTLE_SECONDS=3.0  # see config/default.toml
# INFOJOBS_TIMEOUT_MS=15000  # see config/default.toml
# INFOJOBS_DOMAIN=www.infojobs.net  # see config/default.toml
# INFOJOBS_MAX_PAGES=10  # see config/default.toml
# InfoJobs anti-bot (Distil + Geetest) is stricter than Cloudflare; the
# default 1.5s delay between pages is more conservative than Indeed's 1.0s.
# INFOJOBS_INTER_PAGE_DELAY_SECONDS=1.5  # see config/default.toml

# INFOJOBS_LAUNCH_CHANNEL: when set (e.g. "chrome"), Playwright uses the
# system Chrome binary instead of bundled Chromium, giving InfoJobs the same
# TLS/HTTP-2 fingerprint as a real browser session.
# INFOJOBS_LAUNCH_CHANNEL=chrome

# INFOJOBS_CHROMIUM_PATH: absolute path to the Chromium executable. Needed
# when the system Chromium is not at the path Playwright's `channel` option
# expects (e.g. snap Chromium on Linux). To find the path:
#   find /snap -name "chrome" -type f 2>/dev/null
# Common snap path: /snap/chromium/3459/usr/lib/chromium-browser/chrome
# (the revision number may change after system updates).
# INFOJOBS_CHROMIUM_PATH=/snap/chromium/3459/usr/lib/chromium-browser/chrome


# -----------------------------------------------------------------------------
# Cache (per-source aggregator cache + persistent cache backend)
# -----------------------------------------------------------------------------

# TTL for the per-source aggregator cache. `0` disables the cache
# (every call becomes a miss → scraper is invoked every time).
# CACHE_TTL_SECONDS=60.0  # see config/default.toml

# Per-port timeout for the consolidated `GET /jobs/stats` aggregator
# (REQ-PDPRSC-003 — `perf-dashboard-rsc-migration`). Bounds each
# `JobRepositoryPort.count_jobs` call. When a port exceeds this
# budget the aggregator excludes the source from
# `platform_distribution` instead of blocking the response.
# `0` is NOT recommended (a slow port would block indefinitely).
# STATS_PORT_TIMEOUT_SECONDS=2.0

# `memory` (default, in-process dict) or `redis` (shared across workers).
CACHE_BACKEND=memory
# CACHE_REDIS_URL=redis://localhost:6379/0  # see config/default.toml

# Namespace prepended to every Redis key. MUST be non-empty and MUST NOT
# contain `:` (enforced by Settings). Default `jobs-finder`; override per
# deployment to avoid key collision in shared Redis instances.
# CACHE_REDIS_NAMESPACE=jobs-finder  # see config/default.toml
# CACHE_REDIS_DB=0  # see config/default.toml


# -----------------------------------------------------------------------------
# Rate limiter (HTTP layer, per-client-IP token bucket)
# -----------------------------------------------------------------------------

RATE_LIMIT_ENABLED=true

# `memory` (default) or `redis` (shared across workers). The Redis URL/db
# fall back to CACHE_REDIS_URL / CACHE_REDIS_DB when set to "" / -1 below.
RATE_LIMIT_BACKEND=memory
# RATE_LIMIT_REQUESTS=20  # see config/default.toml
# RATE_LIMIT_WINDOW_SECONDS=60.0  # see config/default.toml

# Sentinel: empty string means "use CACHE_REDIS_URL".
RATE_LIMIT_REDIS_URL=
# Sentinel: -1 means "use CACHE_REDIS_DB".
RATE_LIMIT_REDIS_DB=-1
# RATE_LIMIT_REDIS_NAMESPACE=rate-limiter  # see config/default.toml

# JSON list of paths the rate limiter ignores. Default `["/health"]`.
# RATE_LIMIT_EXEMPT_PATHS=["/health"]  # see config/default.toml

# Per-request cost. The aggregator route charges 1 (the per-source
# AsyncThrottles already pace the 3 parallel scraper calls); per-source
# routes charge 1.
# RATE_LIMIT_AGGREGATOR_PATH_COST=1  # see config/default.toml
# RATE_LIMIT_PER_SOURCE_PATH_COST=1  # see config/default.toml

# JSON list of CIDR strings the rate limiter trusts for X-Forwarded-For.
# Default `[]` (no trust — X-Forwarded-For is IGNORED, the security
# default). Set to e.g. `["10.0.0.0/8", "::1/128"]` behind a known proxy.
# RATE_LIMIT_TRUSTED_PROXIES=[]  # see config/default.toml

# -----------------------------------------------------------------------------
# Aggregator ranking
# -----------------------------------------------------------------------------

# `posted_at` (freshness DESC), `priority` (source-priority DESC), or
# `none` (preserves pre-change behavior).
# AGGREGATOR_RANKING_STRATEGY=posted_at  # see config/default.toml

# JSON object `{source: priority}`. Lower number = higher priority.
# Sources not in the map are treated as priority 999 (last).
# AGGREGATOR_PRIORITY_MAP={"linkedin":0,"indeed":1,"infojobs":2}  # see config/default.toml

# Opt-in `keyword_score` relevance ranking. `false` (default) preserves
# the v1 `posted_at desc` sort; `true` sorts by `keyword_score desc,
# posted_at desc` (per-job match rate against the query tokens, with
# title match weighted 0.6 + description match weighted 0.4, capped at
# 1.0). The `query_tokens` is the tokenized `q` query param
# (`tokenize()` from `infrastructure/aggregator_filters.py`). Set to
# `true` when the v1 `posted_at` order surfaces irrelevant jobs (e.g.
# "Recepcionista" jobs sorted above "React Developer" jobs by date).
# The InfoJobs client-side filter is ALWAYS active (per the
# `filter_infojobs_results` aggregator step) — `ENABLE_KEYWORD_SCORING`
# only controls the SORT step, not the filter.
# ENABLE_KEYWORD_SCORING=false


# -----------------------------------------------------------------------------
# LLM chat filter (POST /jobs/chat)
# -----------------------------------------------------------------------------
#
# The chat route is OFF by default. To enable it in a given environment,
# set BOTH:
#   LLM_API_KEY=<your LLM provider key>
#   LLM_FILTER_ENABLED=true
#
# Supported providers:
#   - MiniMax (default): BASE_URL=https://api.minimax.io, MODEL=MiniMax-M3
#   - Groq (free tier): BASE_URL=https://api.groq.com/openai,
#                        MODEL=llama-3.2-3b-preview or llama-3.1-8b-instant
# NOTE: do NOT include /v1 in BASE_URL — the client appends /v1/chat/completions
#
# Groq is FREE (generous rate limits) and recommended for CV adaptation.
# Groq does NOT support the `thinking` parameter — set LLM_SUPPORTS_THINKING=false.
# -----------------------------------------------------------------------------

# LLM provider API key. SecretStr is masked in repr/str (no log leakage).
# REQUIRED to enable the chat filter.
LLM_API_KEY=

# OpenAI-compatible chat completions base URL.
# MiniMax (default): https://api.minimax.io
# Groq (free): https://api.groq.com/openai
# LLM_BASE_URL=https://api.minimax.io  # see config/default.toml

# Model identifier.
# MiniMax: MiniMax-M3 (only model that honors thinking:disabled)
# Groq: llama-3.2-3b-preview, llama-3.1-8b-instant, mixtral-8x7b-32768
# LLM_MODEL=MiniMax-M3  # see config/default.toml

# LLM_TEMPERATURE=0.0  # see config/default.toml
# LLM_MAX_TOKENS=1024  # see config/default.toml
# LLM_REQUEST_TIMEOUT_SECONDS=15.0  # see config/default.toml

# Whether the LLM provider supports `thinking: {"type": "disabled"}`.
# MiniMax: true (default)
# Groq: false (set LLM_SUPPORTS_THINKING=false)
# LLM_SUPPORTS_THINKING=true  # see config/default.toml

# Chat-message length cap (chars). 400-explicit reject on overflow.
# LLM_MAX_MESSAGE_CHARS=1000  # see config/default.toml

# Kill switch. `true` registers the /jobs/chat route + ChatRateLimitMiddleware;
# `false` (default) means the route returns 404. Two-stage rollout:
# code ships disabled, ops flips the switch.
LLM_FILTER_ENABLED=false

# Per-client-IP rate limit for /jobs/chat, requests per minute. Matches
# the main RATE_LIMIT_REQUESTS so the chat bucket has the same per-minute
# capacity as the main bucket.
# LLM_FILTER_RATE_LIMIT_RPM=20  # see config/default.toml


# -----------------------------------------------------------------------------
# Chat filter — 2-stage LLM (intent extraction + directed aggregator)
# -----------------------------------------------------------------------------
#
# Per-call cost: ~$0.005 (2× v1). Per-user rate limit: 20/min.
# Set the API key via direnv (recommended): create .envrc with
# `export LLM_API_KEY=<your-key>` and `direnv allow`. See README for details.
#
# The 2-stage flow adds a stage-1 LLM call (intent extraction) before the
# v1 stage-3 LLM filter call. The stage-1 call returns a structured
# `Intent` (q, location, experience_years, remote, employment_type,
# confidence); the aggregator then scrapes with the extracted `q` /
# `location` (instead of the v1 `q=""` / `location=""` / `limit=20`).
# When `intent.confidence < INTENT_EXTRACTION_CONFIDENCE_THRESHOLD` OR
# the stage-1 LLM call fails, the use case falls back to the v1 single-
# stage path with `used_fallback=True` in the response.
# -----------------------------------------------------------------------------

# Master switch for the 2-stage flow. Set to false to revert to v1
# behavior (the kill switch — REQ-CHAT-INT-005). All other INTENT_*
# env vars are IGNORED when this is false.
# INTENT_EXTRACTION_ENABLED=true  # see config/default.toml

# Confidence threshold for the extracted intent. Below this, fall back
# to the v1 path (a model that returned a low-confidence intent is
# treated as untrustworthy, and the v1 path's empty-`q`/empty-
# `location` scrape is a safer default).
# INTENT_EXTRACTION_CONFIDENCE_THRESHOLD=0.7  # see config/default.toml

# Per-stage-2 aggregator scrape (per source × N sources). Higher = more
# recall (more jobs to filter in stage 3), but more cost / latency.
# 100 is the default; the v1 path uses `limit=20` regardless of this.
# INTENT_MAX_RESULTS=100  # see config/default.toml

# Stage-1 LLM response size cap (small: 7 fields only). 256 tokens is
# generous and keeps the stage-1 call cheap (~$0.0001 vs $0.0025 for
# the 1024-token stage-3 call).
# LLM_STAGE1_MAX_TOKENS=256  # see config/default.toml

# Stage-1 LLM temperature. 0.0 = deterministic (the 7-field extraction
# is well-defined; non-zero temperature invites randomness).
# LLM_STAGE1_TEMPERATURE=0.0  # see config/default.toml

# Number of retries on stage-1 parse failure. 0 = no retry (fail fast
# → v1 fallback). 1 = retry-once with the corrective system prompt
# (the design's deliberate trade: 2× cost on failure, but a 2nd retry
# is unlikely to succeed where the first retry failed). 3 is the cap.
# INTENT_EXTRACTION_RETRY=1  # see config/default.toml


# -----------------------------------------------------------------------------
# Chat filter — streaming SSE endpoint (POST /jobs/chat/stream)
# -----------------------------------------------------------------------------
#
# The streaming endpoint complements the JSON /jobs/chat endpoint. The
# client (EventSource) opens an SSE connection; the server emits
# `event: meta` (2-stage only) → `event: text` (×N) → `event: done` in
# stream order, OR an `event: error` with a stable machine code.
#
# During quiet periods (primarily the stage-2 aggregator scrape wait,
# typically 2-5s), the server emits an SSE comment line (`: keepalive\n\n`)
# so the browser / nginx proxy doesn't time out. `0` disables the
# feature entirely (no keepalive comments).
# -----------------------------------------------------------------------------

# SSE keepalive interval (seconds). Emit a `: keepalive` comment every
# N seconds during quiet periods (stage-2 aggregator scrape) so browsers
# / proxies don't time out. `0` disables. `60.0` upper bound (Chrome
# idle timeout).
# SSE_KEEPALIVE_SECONDS=15.0  # see config/default.toml


# -----------------------------------------------------------------------------
# Scheduler & Persistence (background-scheduler-persistence change)
# -----------------------------------------------------------------------------
#
# OPT-IN: the background scheduler is DISABLED by default. Set
# SCHEDULER_ENABLED=true to enable periodic scraping and persistence.
#
# The app uses ONE of these two backends:
#   1. DATABASE_URL — PostgreSQL/Supabase connection string (production).
#      When set, this takes precedence over DB_PATH.
#   2. DB_PATH — SQLite database file (local dev, default `jobs.db`).

# PostgreSQL/Supabase connection string. Set for production deployments.
# Format: postgresql://user:password@host:port/database
# Example: postgresql://postgres:secret@db.XXX.supabase.co:5432/postgres
# DATABASE_URL=  # comment out to use SQLite (local dev)

# Path to the SQLite database file (fallback when DATABASE_URL is unset).
# DB_PATH=jobs.db  # see config/default.toml

# Master switch. `false` (default) means zero behavioral change: no DB
# connection is opened, no scheduler task is created.
SCHEDULER_ENABLED=false

# Pseudo-random interval between scheduler cycles (seconds). The
# scheduler sleeps `random.uniform(MIN, MAX)` after each complete
# cycle. Default 1500–2100s = ~25–35 min.
# SCHEDULER_MIN_INTERVAL_SECONDS=1500.0  # see config/default.toml
# SCHEDULER_MAX_INTERVAL_SECONDS=2100.0  # see config/default.toml

# JSON list of query objects. Each object has `"keywords"` and
# `"location"`. The scheduler iterates all queries in one cycle,
# scrapes each one, then persists ALL results in a single batch.
# Empty keywords ("") means location-only search (no keyword filtering).
# SCHEDULER_QUERIES=[{"keywords":"","location":"Madrid"},{"keywords":"","location":"Barcelona"},{"keywords":"","location":"Málaga"}]  # see config/default.toml (30 queries by default)

# TTL-based retention (scheduler-retention-history change).
# Number of days to keep jobs in the database. Jobs with `last_seen_at`
# older than `RETENTION_DAYS` days are deleted after each scheduler
# cycle, capped at 1000 rows per call. `0` (default) disables retention
# entirely. Set to a positive integer (e.g. `30`) to enable cleanup.
# RETENTION_DAYS=30  # see config/default.toml


# -----------------------------------------------------------------------------
# Auth — Supabase JWT (backend-user-awareness change + ES256/JWKS migration)
# -----------------------------------------------------------------------------
#
# REQUIRED for per-user authentication. Without these, Depends(get_current_user)
# returns 401 on every protected route and a WARNING is logged at startup.
#
# Supabase project URL. Found in Supabase Dashboard → Settings → API
# → Project URL. Example: https://abc.supabase.co
# SUPABASE_URL=
#
# JWKS URL (typically auto-derived from SUPABASE_URL). The backend
# fetches the ES256 public key from this URL to verify Supabase-issued
# user JWTs. Override ONLY if you self-host Supabase or use a custom
# reverse proxy.
#
#   Default (when SUPABASE_URL is set):
#     {SUPABASE_URL}/auth/v1/.well-known/jwks.json
#
# Migration note (2026-06-23): the previous `SUPABASE_JWT_SECRET`
# (HS256 shared secret) was removed. The signing key never leaves
# Supabase now — the leaked `.env.bak` from 2026-06-23 cannot be used
# to forge tokens. To rotate, create a new JWT Signing Key in
# Supabase (Settings → API → JWT Signing Keys → Create new) and
# mark it as active; the backend will pick it up automatically via
# the `kid` header on each JWT.
#
# SUPABASE_JWT_JWKS_URL=
#
# Service role key from Supabase Dashboard → Settings → API → Project
# API keys → service_role key. Used by SupabaseEngagementRepository to
# write engagement events (cv_adapted) on behalf of the backend. This
# key bypasses RLS — keep it secret, never expose it to the browser.
# SUPABASE_SERVICE_KEY=
#
# Per-user daily CV generation limit. 0 = unlimited. Default 5.
# USER_CV_DAILY_QUOTA=5


# -----------------------------------------------------------------------------
# Auth — redirect URLs (frontend-only, documented here as single source of truth)
# -----------------------------------------------------------------------------
#
# These vars are NOT read by the backend — auth lives entirely in the
# Supabase project + the frontend. They are documented here as the
# single source of truth for which URLs the dashboard's Authentication
# → URL Configuration section must allow (Site URL + Additional redirect
# URLs).
#
# Dev / local:
SUPABASE_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
# Prod (set this in your production .env):
# SUPABASE_AUTH_REDIRECT_URL=https://jobs-finder.app/auth/callback
#
# Account deletion (Feature C) is a Postgres SECURITY DEFINER RPC
# (backend/supabase/migrations/20260621_0001_delete_current_user_rpc.sql).
# Apply it via `supabase db push` or by pasting it into the
# dashboard's SQL editor. See backend/supabase/README.md for the
# full workflow + IRREVERSIBILITY caveat.
