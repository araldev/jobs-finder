# =============================================================================
# jobs-finder — Backend operator override template
# =============================================================================
#
# Copy this file to `local.toml` (same directory, gitignored) and
# uncomment ONLY the lines you want to override. `load_settings()`
# reads `default.toml` first, then `local.toml` — `local.toml` wins
# for any key present in both.
#
# Use `local.toml` when:
#   - You need to tweak ONE operational knob without forking the
#     upstream defaults (`default.toml`).
#   - You don't want to touch `backend/.env` (which is reserved for
#     secrets + per-environment switches).
#   - You're running a multi-deployment setup where one shared
#     `default.toml` is the baseline and each deployment tweaks
#     different values via `local.toml`.
#
# DO NOT commit `local.toml` to the repo. It is gitignored alongside
# `.env`. The precedence contract:
#
#   env vars (already set)  >  local.toml  >  default.toml  >  field defaults
#
# =============================================================================


# ── LinkedIn scraper ──────────────────────────────────────────────────────
# LINKEDIN_THROTTLE_SECONDS = 3.0
# LINKEDIN_REQUEST_TIMEOUT_MS = 10000
# LINKEDIN_LOG_LEVEL = "INFO"
# LINKEDIN_LOG_FORMAT = "json"
# LINKEDIN_MAX_PAGES = 10
# LINKEDIN_INTER_PAGE_DELAY_SECONDS = 1.0
# LINKEDIN_XVFB_DISPLAY = ""
# LINKEDIN_LAUNCH_CHANNEL = ""


# ── Indeed scraper ─────────────────────────────────────────────────────────
# INDEED_THROTTLE_SECONDS = 3.0
# INDEED_TIMEOUT_MS = 15000
# INDEED_DOMAIN = "es.indeed.com"
# INDEED_MAX_PAGES = 10
# INDEED_INTER_PAGE_DELAY_SECONDS = 1.0


# ── InfoJobs scraper ───────────────────────────────────────────────────────
# INFOJOBS_THROTTLE_SECONDS = 3.0
# INFOJOBS_TIMEOUT_MS = 15000
# INFOJOBS_DOMAIN = "www.infojobs.net"
# INFOJOBS_MAX_PAGES = 10
# INFOJOBS_INTER_PAGE_DELAY_SECONDS = 1.5
# INFOJOBS_LAUNCH_CHANNEL = ""
# INFOJOBS_CHROMIUM_PATH = ""


# ── Cache (per-source aggregator + persistent backend) ─────────────────────
# CACHE_TTL_SECONDS = 60.0
# CACHE_REDIS_URL = "redis://localhost:6379/0"
# CACHE_REDIS_NAMESPACE = "jobs-finder"
# CACHE_REDIS_DB = 0


# ── Rate limiter (HTTP layer, per-client-IP token bucket) ──────────────────
# RATE_LIMIT_REQUESTS = 20
# RATE_LIMIT_WINDOW_SECONDS = 60.0
# RATE_LIMIT_REDIS_NAMESPACE = "rate-limiter"
# RATE_LIMIT_EXEMPT_PATHS = '["/health"]'
# RATE_LIMIT_AGGREGATOR_PATH_COST = 1
# RATE_LIMIT_PER_SOURCE_PATH_COST = 1
# RATE_LIMIT_TRUSTED_PROXIES = "[]"


# ── Aggregator ranking ─────────────────────────────────────────────────────
# AGGREGATOR_RANKING_STRATEGY = "posted_at"
# AGGREGATOR_PRIORITY_MAP = '{"linkedin": 0, "indeed": 1, "infojobs": 2}'
# ENABLE_KEYWORD_SCORING = false


# ── LLM chat filter ────────────────────────────────────────────────────────
# LLM_BASE_URL = "https://api.minimax.io"
# LLM_MODEL = "MiniMax-M3"
# LLM_TEMPERATURE = 0.0
# LLM_MAX_TOKENS = 4096
# LLM_REQUEST_TIMEOUT_SECONDS = 15.0
# LLM_MAX_MESSAGE_CHARS = 1000
# LLM_FILTER_ENABLED = false
# LLM_FILTER_RATE_LIMIT_RPM = 20
# LLM_SUPPORTS_THINKING = true
# LLM_STAGE1_MAX_TOKENS = 256
# LLM_STAGE1_TEMPERATURE = 0.0


# ── Chat filter — 2-stage intent extraction ────────────────────────────────
# INTENT_EXTRACTION_ENABLED = true
# INTENT_EXTRACTION_CONFIDENCE_THRESHOLD = 0.0
# INTENT_MAX_RESULTS = 100
# INTENT_EXTRACTION_RETRY = 1


# ── SSE keepalive (chat streaming endpoint) ────────────────────────────────
# SSE_KEEPALIVE_SECONDS = 15.0


# ── Scheduler & persistence ────────────────────────────────────────────────
# DB_PATH = "jobs.db"
# SCHEDULER_MIN_INTERVAL_SECONDS = 1500.0
# SCHEDULER_MAX_INTERVAL_SECONDS = 2100.0
# SCHEDULER_QUERIES = '[]'
# RETENTION_DAYS = 0
