# =============================================================================
# jobs-finder — Production environment variables
# =============================================================================
# Copy this file to .env.production, fill in your values.
#   cp .env.production.example .env.production
#   # Then edit .env.production
#
# Run:
#   docker compose up -d

# ── Supabase (PostgreSQL + Auth) ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── API Keys ──────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for backend-to-backend auth.
# The frontend (Vercel) uses this to authenticate requests via Route Handlers.
API_KEYS=["api-key-for-frontend","backup-key"]

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin(s) that can call the API directly (e.g. your Vercel domain).
# JSON array format:
LINKEDIN_CORS_ALLOW_ORIGINS=["https://jobsfinder.vercel.app"]

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Runs background job scraping every ~15 minutes.
SCHEDULER_ENABLED=true

# ── LinkedIn scraper ──────────────────────────────────────────────────────────
# Credentials for the auto cookie refresh (no li_at needed if these are set).
LINKEDIN_EMAIL=your-linkedin-email
LINKEDIN_PASSWORD=your-linkedin-password

# Optional: cookie file path (if you extracted cookies manually).
# The JsonLinkedInAuthCookiesAdapter reads from linkedin_cookies.json
# in the /app working directory (mounted as a volume).

# ── Request timeouts ──────────────────────────────────────────────────────────
LINKEDIN_REQUEST_TIMEOUT_MS=30000
LINKEDIN_COOKIE_REFRESH_TIMEOUT_SECONDS=300.0

# ── LLM / Chat (optional) ────────────────────────────────────────────────────
# Only needed if you use the AI-powered chat/CV features.
# LLM_API_KEY=your-openai-key
# LLM_FILTER_ENABLED=true

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
